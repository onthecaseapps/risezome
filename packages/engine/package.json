{
  "name": "@risezome/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./chunker": {
      "types": "./dist/chunker/index.d.ts",
      "default": "./dist/chunker/index.js"
    },
    "./embed": {
      "types": "./dist/embed/index.d.ts",
      "default": "./dist/embed/index.js"
    },
    "./skills": {
      "types": "./dist/skills/index.d.ts",
      "default": "./dist/skills/index.js"
    },
    "./transcribe": {
      "types": "./dist/transcribe/index.d.ts",
      "default": "./dist/transcribe/index.js"
    },
    "./synthesize": {
      "types": "./dist/synthesize/index.d.ts",
      "default": "./dist/synthesize/index.js"
    },
    "./relevance": {
      "types": "./dist/relevance/index.d.ts",
      "default": "./dist/relevance/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "default": "./dist/router/index.js"
    },
    "./summarize": {
      "types": "./dist/summarize/index.d.ts",
      "default": "./dist/summarize/index.js"
    },
    "./eval": {
      "types": "./dist/eval/index.d.ts",
      "default": "./dist/eval/index.js"
    },
    "./contextualize": {
      "types": "./dist/contextualize/index.d.ts",
      "default": "./dist/contextualize/index.js"
    },
    "./summarize-doc": {
      "types": "./dist/summarize-doc/index.d.ts",
      "default": "./dist/summarize-doc/index.js"
    },
    "./query-expand": {
      "types": "./dist/query-expand/index.d.ts",
      "default": "./dist/query-expand/index.js"
    },
    "./query-route": {
      "types": "./dist/query-route/index.d.ts",
      "default": "./dist/query-route/index.js"
    },
    "./gaps": {
      "types": "./dist/gaps/index.d.ts",
      "default": "./dist/gaps/index.js"
    },
    "./parent-doc": {
      "types": "./dist/parent-doc/index.d.ts",
      "default": "./dist/parent-doc/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.build.json && tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@risezome/shared-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
