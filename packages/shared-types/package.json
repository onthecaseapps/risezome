{
  "name": "@risezome/shared-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./audio": {
      "types": "./dist/audio.d.ts",
      "default": "./dist/audio.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.build.json && tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
