{
  "name": "risezome",
  "version": "0.0.0",
  "private": true,
  "description": "Risezome — a cloud meeting-context copilot: a Recall.ai bot joins your calls, retrieves relevant context from connected sources (GitHub, Trello, Jira, Confluence), and surfaces synthesized answers in real time.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "console": "tsx scripts/dev-console/server.ts",
    "env:use": "bash scripts/use-env.sh",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . && pnpm lint:org-scope",
    "lint:org-scope": "node scripts/lint/check-service-role-org-scope.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
