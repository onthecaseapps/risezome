# Supabase project URL and keys. Find them at:
#   https://app.supabase.com/project/<ref>/settings/api
# The publishable key (was: anon key) is safe to expose; the secret key
# (was: service_role key) must NEVER be committed and is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Google OAuth 2.0 client (Google Cloud Console → APIs & Services →
# Credentials). The CLIENT_ID is configured in the Supabase Dashboard's
# Auth → Providers → Google. The SECRET goes into Supabase as well; we
# don't store it in Vercel env (U2 reads it via Supabase). Listed here
# so operators know it exists and where it belongs.
#
# Required Google OAuth redirect URIs to register:
#   https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
#   http://localhost:3000/api/auth/callback
#
# Required Google OAuth scopes (U2 requests these at signInWithOAuth time):
#   openid email profile
#   https://www.googleapis.com/auth/calendar.events.readonly
GOOGLE_OAUTH_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR-CLIENT-SECRET

# Symmetric encryption key for the user's Google refresh token at rest.
# Generate locally with: openssl rand -base64 32
# Treat like a secret key; rotating it invalidates all stored refresh
# tokens (users would need to re-auth). Server-only.
USER_TOKEN_ENCRYPTION_KEY=REPLACE_ME_32_BYTES_BASE64

# GitHub App credentials. Generate by running:
#   node apps/portal/scripts/register-github-app.mjs
# That script walks you through GitHub's App Manifest flow and prints
# these env vars. PEM key is base64-encoded because env-var newlines
# get mangled by most hosting providers.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY_BASE64=

# HMAC secret for the install-flow CSRF state token. Generate locally:
#   openssl rand -base64 32
# Used to sign the state param sent to GitHub's install URL; verified
# in the install-callback route handler. Server-only.
INSTALL_STATE_HMAC_SECRET=REPLACE_ME_32_BYTES_BASE64

# Voyage AI API key. Used by the indexer to embed text + code chunks
# (voyage-3-large + voyage-code-3, both 1024-dim). Create at:
#   https://dash.voyageai.com/api-keys
# Server-only; never exposed to the browser.
VOYAGE_API_KEY=

# Inngest credentials. Production: set automatically by the Vercel-Inngest
# integration. Local dev: leave EMPTY — the Inngest dev CLI runs unsigned
# at http://localhost:8288 and discovers functions at
# http://localhost:3000/api/inngest with no keys needed.
#   npx inngest-cli@latest dev
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Recall.ai. Bot launch (Create Bot) calls Recall over HTTPS; the bot
# streams transcripts back to the bot-worker over wss (U10). ZDR is
# enforced in code (R11b) — Recall.ai's account-level ZDR mode is also
# recommended but the per-request `retention: null` is what we rely on.
#
# RECALL_API_KEY            — server-only
# RECALL_REGION             — Recall.ai region. Default: us-east-1
# RECALL_DEEPGRAM_KEY       — BYO Deepgram key for nova-3 streaming
# BOT_WORKER_BASE_URL       — wss URL the bot connects back to.
#                             Local dev: wss://<your-tunnel>.ngrok.io
#                             Prod: wss://bot-worker.risezome.app
# RECALL_MAX_DURATION_SECONDS — safety cap on how long a bot stays in
#                             a meeting. Applied to both
#                             in_call_recording_timeout and
#                             in_call_not_recording_timeout so a
#                             runaway bug can't leave a bot in
#                             indefinitely. Default 300 (5 min) for
#                             dev/test. Lift to 3600+ for prod once
#                             the surface is proven.
RECALL_API_KEY=
RECALL_REGION=us-east-1
RECALL_DEEPGRAM_KEY=
BOT_WORKER_BASE_URL=
RECALL_MAX_DURATION_SECONDS=300
