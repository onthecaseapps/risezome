# Supabase project URL and keys. Find them at:
#   https://app.supabase.com/project/<ref>/settings/api
# The publishable key (was: anon key) is safe to expose; the secret key
# (was: service_role key) must NEVER be committed and is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Google OAuth 2.0 client (Google Cloud Console → APIs & Services →
# Credentials). The CLIENT_ID is configured in the Supabase Dashboard's
# Auth → Providers → Google. The SECRET goes into Supabase as well; we
# don't store it in Vercel env (U2 reads it via Supabase). Listed here
# so operators know it exists and where it belongs.
#
# Required Google OAuth redirect URIs to register:
#   https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
#   http://localhost:3000/api/auth/callback
#
# Required Google OAuth scopes (U2 requests these at signInWithOAuth time):
#   openid email profile
#   https://www.googleapis.com/auth/calendar.events.readonly
GOOGLE_OAUTH_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR-CLIENT-SECRET
