# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV WORKFLOW (two developers, isolated). See
# docs/runbooks/two-developer-local-setup.md.
#
#   1. cp apps/portal/.env.example apps/portal/.env.dev   (this file → your dev file)
#   2. Fill in YOUR secrets + (for hosted mode) YOUR own Supabase project below.
#   3. Run `pnpm dev` — it asks for a developer tag once (remembered in .dev-tag),
#      derives the per-dev hostnames, wires the active .env.local, and starts
#      everything with one log stream.
#
# `pnpm dev` (or `pnpm env:use <tag> local|hosted`) GENERATES apps/portal/.env.local
# from this .env.dev. Don't edit .env.local by hand. In `local` mode the Supabase
# vars below are overridden with the local `supabase start` stack; in `hosted`
# mode your values below are used. RISEZOME_DEV_ORIGIN / BOT_WORKER_BASE_URL are
# derived from your tag — leave them unset here.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL and keys (used in HOSTED mode; auto-overridden in local).
# Find them at: https://app.supabase.com/project/<ref>/settings/api
# The publishable key (was: anon key) is safe to expose; the secret key
# (was: service_role key) must NEVER be committed and is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Direct Postgres connection for the corpus indexer's bulk writes. PostgREST
# (the REST API the secret key talks to) is behind Cloudflare's WAF, which 403s
# chunk bodies containing HTML-like source; the indexer writes corpus rows over
# this direct connection instead. Use the Supabase TRANSACTION pooler URI
# (Dashboard → Settings → Database → Connection string → Transaction pooler),
# which includes the DB password. Server-only; never commit the real value.
SUPABASE_DB_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres

# Per-developer tunnel origin for Next dev allowedDevOrigins. DERIVED from your
# tag by `pnpm dev` / use-env.sh (dev-<tag>.risezome.app) — leave unset here.
# RISEZOME_DEV_ORIGIN=

# Optional: local-dev Recall isolation tag. Only needed if you share ONE Recall
# Environment with your partner — tags launched bots so a shared webhook can
# demux by owner. With separate per-dev Recall Environments (recommended), leave
# this unset.
# RECALL_DEVELOPER_ID=

# Google OAuth 2.0 client (Google Cloud Console → APIs & Services →
# Credentials). The CLIENT_ID is configured in the Supabase Dashboard's
# Auth → Providers → Google. The SECRET goes into Supabase as well; we
# don't store it in Vercel env (U2 reads it via Supabase). Listed here
# so operators know it exists and where it belongs.
#
# Required Google OAuth redirect URIs to register:
#   https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
#   http://localhost:3000/api/auth/callback
#
# Required Google OAuth scopes (U2 requests these at signInWithOAuth time):
#   openid email profile
#   https://www.googleapis.com/auth/calendar.events.readonly
GOOGLE_OAUTH_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR-CLIENT-SECRET

# LEGACY — needed only by the one-time KMS migration; remove after.
# The pre-KMS global pgcrypto key. Production crypto now uses per-org AWS KMS
# (@risezome/crypto); the only remaining consumer is the U11 backfill
# (migrate-encryption-to-kms), which decrypts pre-KMS rows under this key before
# re-encrypting them per-org. Once that backfill has run and verified zero rows
# < KMS_ESDK (and the U13 drop migration is applied), this can be deleted.
# Server-only; treat like a secret key.
USER_TOKEN_ENCRYPTION_KEY=REPLACE_ME_32_BYTES_BASE64

# DEV/CI ONLY — local RawAES fallback; prod uses AWS KMS (leave unset).
# When set, @risezome/crypto derives a per-org wrapping key from this secret
# instead of calling AWS KMS, so local dev and CI run without AWS access.
RISEZOME_DEV_CRYPTO_KEY=

# GitHub App credentials. Generate by running:
#   node apps/portal/scripts/register-github-app.mjs
# That script walks you through GitHub's App Manifest flow and prints
# these env vars. PEM key is base64-encoded because env-var newlines
# get mangled by most hosting providers.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY_BASE64=

# HMAC secret for the install-flow CSRF state token. Generate locally:
#   openssl rand -base64 32
# Used to sign the state param sent to GitHub's install URL; verified
# in the install-callback route handler. Server-only.
INSTALL_STATE_HMAC_SECRET=REPLACE_ME_32_BYTES_BASE64

# Atlassian OAuth 2.0 (3LO) app credentials — powers BOTH the Jira and
# Confluence sources (one app covers both). Create at:
#   https://developer.atlassian.com/console/myapps/  → OAuth 2.0 integration
# Then, in that app:
#   • Permissions → add the Jira + Confluence APIs and enable these GRANULAR
#     scopes (must match apps/portal/app/_lib/atlassian.ts). Granular is
#     mandatory — the client uses the Confluence REST API v2, which rejects
#     classic scopes; classic + granular can't be mixed, so Jira is granular too:
#       read:project:jira  read:issue:jira  read:jql:jira
#       read:comment:jira  read:user:jira
#       read:space:confluence  read:page:confluence
#       offline_access   (gates the rotating refresh token)
#   • Authorization → OAuth 2.0 (3LO) → set the Callback URL to:
#       https://<your-portal-origin>/api/atlassian/callback
#       (local dev: http://localhost:3000/api/atlassian/callback)
# Copy the Client ID + Secret from the app's Settings tab. Server-only.
# Leave BOTH unset to disable Jira/Confluence (the Sources page then shows
# "not configured" instead of erroring). Reuses pending_installations +
# INSTALL_STATE_HMAC_SECRET above for the connect-flow CSRF state.
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# Voyage AI API key. Used by the indexer to embed text + code chunks
# (voyage-3-large + voyage-code-3, both 1024-dim). Create at:
#   https://dash.voyageai.com/api-keys
# Server-only; never exposed to the browser.
VOYAGE_API_KEY=

# Inngest credentials. Production: set automatically by the Vercel-Inngest
# integration. Local dev: leave EMPTY — the Inngest dev CLI runs unsigned
# at http://localhost:8288 and discovers functions at
# http://localhost:3000/api/inngest with no keys needed.
#   npx inngest-cli@latest dev
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Recall.ai. Bot launch (Create Bot) calls Recall over HTTPS; the bot
# streams transcripts back to the bot-worker over wss (U10). ZDR is
# enforced in code (R11b) — Recall.ai's account-level ZDR mode is also
# recommended but the per-request `retention: null` is what we rely on.
#
# RECALL_API_KEY            — server-only
# RECALL_REGION             — Recall.ai region. Default: us-east-1
# RECALL_DEEPGRAM_KEY       — BYO Deepgram key for nova-3 streaming
# BOT_WORKER_BASE_URL       — wss URL the bot connects back to.
#                             Local dev: wss://<your-tunnel>.ngrok.io
#                             Prod: wss://bot-worker.risezome.app
# RECALL_MAX_DURATION_SECONDS — safety cap on how long a bot stays in
#                             a meeting. Applied to both
#                             in_call_recording_timeout and
#                             in_call_not_recording_timeout so a
#                             runaway bug can't leave a bot in
#                             indefinitely. Default 300 (5 min) for
#                             dev/test. Lift to 3600+ for prod once
#                             the surface is proven.
RECALL_API_KEY=
RECALL_REGION=us-east-1
RECALL_DEEPGRAM_KEY=
BOT_WORKER_BASE_URL=
RECALL_MAX_DURATION_SECONDS=300

# Shared secret for the bot-worker JWT. The portal signs (in U8's
# launcher) and the bot-worker verifies (in apps/bot-worker/src/jwt.ts).
# Generate with: openssl rand -base64 32
# MUST match the value set in apps/bot-worker's env.
BOT_WORKER_SECRET=

# HTTP base URL of the bot-worker (no trailing slash). Used by the
# Recall webhook handler to POST /meetings/:id/end when bot.call_ended
# fires so the bot-worker can flush in-memory state.
# Local dev:  http://localhost:8787
# Prod:       https://bot-worker.risezome.app
BOT_WORKER_HTTP_URL=http://localhost:8787

# Svix secret for Recall.ai webhook signature verification. Get from
# the Recall.ai dashboard's Webhooks settings (Svix-style HMAC). Used
# by /api/recall/webhook.
RECALL_WEBHOOK_SECRET=
