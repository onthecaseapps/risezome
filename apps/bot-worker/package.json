{
  "name": "@risezome/bot-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.build.json && tsc --noEmit -p tsconfig.json",
    "start": "node ./dist/index.js",
    "dev": "tsx --env-file=.env ./src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.1",
    "@risezome/engine": "workspace:*",
    "@risezome/shared-types": "workspace:*",
    "@supabase/supabase-js": "^2.106.2",
    "fastify": "^5.2.1",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
