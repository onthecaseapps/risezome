# Bot-worker env. Copy to .env and fill in values.
# `pnpm --filter @risezome/bot-worker dev` reads this via tsx --env-file=.env.

# Required: Supabase service-role credentials. Bot-worker writes
# meeting_events, cards, syntheses, and updates meetings.status with
# the service-role key (bypasses RLS, always filters by org_id).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Required: shared secret with the portal for the bot-worker WS JWT.
# Portal signs in U8 launcher, bot-worker verifies on WS upgrade.
# Generate with: openssl rand -base64 32
# MUST match apps/portal/.env.local's BOT_WORKER_SECRET.
BOT_WORKER_SECRET=REPLACE_ME_32_BYTES_BASE64

# Optional: Voyage API key. When set, bot-worker runs per-utterance
# retrieval against the indexed corpus + emits cards. When unset,
# transcripts still stream but no cards.
VOYAGE_API_KEY=

# Optional: Anthropic API key. When set, after cards are emitted the
# bot-worker runs them through Claude synthesis and streams batched
# synthesisDelta broadcasts to the live page's right panel. When unset,
# cards still work but no synthesis. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # optional override

# Port to listen on (default 8787).
BOT_WORKER_PORT=8787
