# Bot-worker env. For the two-developer local workflow:
#   1. cp apps/bot-worker/.env.example apps/bot-worker/.env.dev  (fill in below)
#   2. Run `pnpm dev` (or `pnpm env:use <tag> local|hosted`) — it GENERATES the
#      active apps/bot-worker/.env that `tsx --env-file=.env` reads. Don't edit
#      .env by hand. See docs/runbooks/two-developer-local-setup.md.

# Required: Supabase service-role credentials (used in HOSTED mode; auto-overridden
# in local mode with the local `supabase start` stack). Bot-worker writes
# meeting_events, cards, syntheses, and updates meetings.status with the
# service-role key (bypasses RLS, always filters by org_id).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# DEV/CI ONLY — local RawAES fallback; prod uses AWS KMS (leave unset).
# When set, @risezome/crypto derives a per-org wrapping key from this secret
# instead of calling AWS KMS. MUST match the portal's value so the
# portal↔bot-worker key-equality invariant holds (a transcript encrypted by
# one decrypts on the other).
RISEZOME_DEV_CRYPTO_KEY=

# Required: shared secret with the portal for the bot-worker WS JWT.
# Portal signs in U8 launcher, bot-worker verifies on WS upgrade.
# Generate with: openssl rand -base64 32
# MUST match apps/portal/.env.local's BOT_WORKER_SECRET.
BOT_WORKER_SECRET=REPLACE_ME_32_BYTES_BASE64

# Optional: Voyage API key. When set, bot-worker runs per-utterance
# retrieval against the indexed corpus + emits cards. When unset,
# transcripts still stream but no cards.
VOYAGE_API_KEY=

# Optional: Anthropic API key. When set, after cards are emitted the
# bot-worker runs them through Claude synthesis and streams batched
# synthesisDelta broadcasts to the live page's right panel. When unset,
# cards still work but no synthesis. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # optional override

# Port to listen on (default 8787).
BOT_WORKER_PORT=8787

# Optional: live GitHub skills. These are PLATFORM credentials for the
# Risezome GitHub App (the SAME app the portal uses) — one app serves
# all tenants. When BOTH are set, the bot-worker registers the live-API
# GitHub skills (github_count via the Search API, github_issue_assignees,
# github_by_assignee_count, github_by_assignee_list,
# github_issue_progress). Each skill resolves the meeting org's
# installation token + connected repos from the `sources` table at call
# time — customers connect repos on the Sources page and set NOTHING.
# When unset, github_count falls back to the indexed corpus and the
# assignee/progress skills are disabled (logged: github.live.disabled).
#
# Copy these from apps/portal/.env.local — they're the same App creds.
# GITHUB_APP_PRIVATE_KEY_BASE64 is the App's PEM private key, base64-encoded.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=

# Optional: live Trello skills. PLATFORM Power-Up API key (the SAME key the
# portal uses) — one key serves all tenants. When set, the bot-worker registers
# the live-API Trello skills (trello_count, trello_list, trello_by_member,
# trello_recently_active, trello_board_breakdown). Each resolves the meeting
# org's read token + connected boards from `trello_connections` + `sources` at
# call time — customers connect a board on the Sources page and set NOTHING.
# When unset, the Trello skills don't register and Trello questions fall back to
# RAG over the indexed corpus (logged: trello.live.disabled).
#
# Copy from apps/portal/.env.local (key name: TRELLO_API_KEY).
TRELLO_API_KEY=
