{
  "name": "@upwell/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.build.json && tsc --noEmit -p tsconfig.json",
    "start": "node ./dist/index.js",
    "dev": "node --watch --import ./loader.mjs ./src/index.ts"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.1",
    "@upwell/shared-types": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.3",
    "ws": "^8.18.0"
  }
}
