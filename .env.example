# Upwell daemon environment.
#
# Copy this file to .env (in the repo root or in your data dir,
# default ~/.local/share/upwell/.env) and fill in real values.
#
# .env, .env.local, and .env.*.local are already in .gitignore.
# Anything already exported in your shell wins over values in this file.

# --- Required for `upwell serve` -------------------------------------------

# Deepgram API key for streaming transcription.
# Sign up: https://console.deepgram.com/ ($200 free credit)
DEEPGRAM_API_KEY=

# Voyage AI API key for embeddings.
# Sign up: https://dash.voyageai.com/ (free tokens on signup)
VOYAGE_API_KEY=

# Optional: pick which Voyage model to use. Defaults: voyage-3-large for text,
# voyage-code-3 for code. See https://docs.voyageai.com/docs/embeddings for
# the current model list; newer/larger models generally have better recall
# at the same dimension. Cache invalidates if you change the model.
# VOYAGE_TEXT_MODEL=voyage-3-large
# VOYAGE_CODE_MODEL=voyage-code-3

# Optional: throttle inter-batch sends to stay under Voyage's RPM cap.
# Free tier is ~3 RPM, so 20000 (20s between batches) stays safely under.
# Default 0 (no delay, retry on 429 reactively).
# VOYAGE_BATCH_DELAY_MS=20000

# Optional: how many chunks to embed per Voyage API call. Default 64.
# VOYAGE_EMBED_BATCH_SIZE=64

# Absolute path to the built Linux audio sidecar binary.
# Build with: sudo apt install libpulse-dev && cd sidecars/linux && make
UPWELL_SIDECAR_PATH=/home/you/dev/upwell/sidecars/linux/build/upwell-sidecar-linux

# SHA-256 of the sidecar binary above. Compute with:
#   ./sidecars/linux/scripts/compute-sha256.sh
# The daemon refuses to spawn a sidecar whose hash doesn't match.
UPWELL_SIDECAR_SHA=

# PulseAudio source to capture (the active output's monitor for system audio).
# Resolve at shell time:  export PULSE_SOURCE="$(pactl get-default-sink).monitor"
PULSE_SOURCE=

# Optional: port to bind. 0 (default) picks an ephemeral port.
# UPWELL_PORT=4337

# --- Required for `upwell index <owner/repo>` ------------------------------

# Fine-grained PAT or classic PAT with `repo:read` + `read:user`.
# Sign in to GitHub → Settings → Developer settings → Personal access tokens.
GITHUB_TOKEN=

# --- Optional ---------------------------------------------------------------

# Skip the in-repo file walk during `upwell index` (issues+PRs only).
# UPWELL_INDEX_FILES=false

# Override which .env file is loaded first.
# UPWELL_ENV_FILE=/absolute/path/to/some.env
