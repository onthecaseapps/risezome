# Upwell daemon environment.
#
# Copy this file to .env (in the repo root or in your data dir,
# default ~/.local/share/upwell/.env) and fill in real values.
#
# .env, .env.local, and .env.*.local are already in .gitignore.
# Anything already exported in your shell wins over values in this file.

# --- Required for `upwell serve` -------------------------------------------

# Deepgram API key for streaming transcription.
# Sign up: https://console.deepgram.com/ ($200 free credit)
DEEPGRAM_API_KEY=

# Voyage AI API key for embeddings.
# Sign up: https://dash.voyageai.com/ (free tokens on signup)
VOYAGE_API_KEY=

# Optional: pick which Voyage model to use. Defaults: voyage-3-large for text,
# voyage-code-3 for code. See https://docs.voyageai.com/docs/embeddings for
# the current model list; newer/larger models generally have better recall
# at the same dimension. Cache invalidates if you change the model.
# VOYAGE_TEXT_MODEL=voyage-3-large
# VOYAGE_CODE_MODEL=voyage-code-3

# Optional: throttle inter-batch sends to stay under Voyage's RPM cap.
# Free tier is ~3 RPM, so 20000 (20s between batches) stays safely under.
# Default 0 (no delay, retry on 429 reactively).
# VOYAGE_BATCH_DELAY_MS=20000

# Optional: how many chunks to embed per Voyage API call. Default 64.
# VOYAGE_EMBED_BATCH_SIZE=64

# Absolute path to the built Linux audio sidecar binary.
# Build with: sudo apt install libpulse-dev && cd sidecars/linux && make
UPWELL_SIDECAR_PATH=/home/you/dev/upwell/sidecars/linux/build/upwell-sidecar-linux

# SHA-256 of the sidecar binary above. Compute with:
#   ./sidecars/linux/scripts/compute-sha256.sh
# The daemon refuses to spawn a sidecar whose hash doesn't match.
UPWELL_SIDECAR_SHA=

# PulseAudio source to capture (the active output's monitor for system audio).
# Resolve at shell time:  export PULSE_SOURCE="$(pactl get-default-sink).monitor"
PULSE_SOURCE=

# Optional: port to bind. 0 (default) picks an ephemeral port.
# UPWELL_PORT=4337

# Optional: pin the session token (64 hex chars / 32 bytes). When unset, the
# daemon uses the per-machine token at ~/.local/share/upwell/session-token.
# Useful for curl/script testing so the bearer doesn't change between runs.
# UPWELL_SESSION_TOKEN=

# --- Optional: LLM synthesis (Claude Haiku 4.5) ----------------------------

# Anthropic API key for the synthesis card. When unset, synthesis is
# disabled entirely (no outbound LLM calls; raw retrieval cards still
# render). Grant consent before first use:
#   pnpm daemon consent grant anthropic
# Sign up: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# Optional: pick which Anthropic model to use. Default: claude-haiku-4-5.
# Prompt caching engages above 4096 tokens of static prefix; we ship a
# 5-7 few-shot prefix sized to clear that bar.
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: gate synthesis on top retrieval result's RRF score.
# Default 0.025 (≈ top rank in at least one ranker). Lower = more
# synthesis calls (cost, noise); higher = fewer (misses).
# UPWELL_SYNTHESIS_MIN_SCORE=0.025

# Optional: how many top cards to pass as numbered sources. Default 3.
# UPWELL_SYNTHESIS_TOP_N=3

# Optional: hard ceiling on synthesis output tokens. Default 150
# (typical 1-3 sentence answer is well under this).
# UPWELL_SYNTHESIS_MAX_TOKENS=150

# --- Utterance-relevance pre-classifier ------------------------------------
#
# The pipeline gates each utterance through a tristate heuristic before
# spending money on retrieval or synthesis. Obvious filler (single-word
# acks, social pleasantries, meta-meeting talk) is dropped at zero cost.
# Ambiguous utterances fire a small Claude call that returns surface or
# skip with a confidence score. The threshold below controls how
# confident the LLM must be to actually skip.

# Optional: confidence threshold the LLM must clear to honor a skip
# decision. Default 0.7 — model self-reports below this default to
# surface. Dial up (0.85, 0.95) if dogfood shows false-skips of real
# questions. Set high enough that the LLM never silently drops content.
# UPWELL_RELEVANCE_SKIP_THRESHOLD=0.7

# Optional: hard timeout (ms) on the relevance classifier call. On
# timeout the call is treated as surface and the pipeline continues.
# Default 3000ms.
# UPWELL_RELEVANCE_TIMEOUT_MS=3000

# --- Router + skills framework ---------------------------------------------
#
# The ANTHROPIC_API_KEY above also enables the router classifier. When the
# heuristic detects a possible aggregation / list / filter query (e.g.
# "how many open issues are there"), the daemon calls Claude to pick a
# typed read-only skill from the registered skill set. The skill executes
# against the local SQLite corpus and its result feeds the synthesizer as
# a numbered source. No separate API key, no separate consent grant. To
# disable the router specifically while keeping synthesis enabled, no
# env knob exists in v1 — but you can revoke 'anthropic' consent (which
# gates both surfaces).

# --- Required for `upwell index <owner/repo>` ------------------------------

# Fine-grained PAT or classic PAT with `repo:read` + `read:user`.
# Sign in to GitHub → Settings → Developer settings → Personal access tokens.
GITHUB_TOKEN=

# --- Optional ---------------------------------------------------------------

# Skip the in-repo file walk during `upwell index` (issues+PRs only).
# UPWELL_INDEX_FILES=false

# Override which .env file is loaded first.
# UPWELL_ENV_FILE=/absolute/path/to/some.env

# Trello connector (read scope). Power-Up API key from https://trello.com/power-ups/admin
TRELLO_API_KEY=
